# ---- Composer-managed dependencies (rebuilt via composer install) ----
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/libraries/
/drush/contrib/

# ---- Drupal scaffold files (regenerated by composer) ----
/web/autoload.php
/web/index.php
/web/robots.txt
/web/update.php
/web/web.config
/web/.htaccess
/web/sites/default/default.services.yml
/web/sites/default/default.settings.php

# ---- Site-specific runtime files (never commit) ----
/web/sites/*/files/
/web/sites/*/private/
/web/sites/*/settings.local.php
/web/sites/*/settings.php
!/web/sites/default/settings.php.example

# Keep the settings.php out unless you deliberately want to version it;
# if you DO commit settings.php (common when secrets are injected via env
# vars/Secrets Manager rather than hardcoded), remove the line above.

# ---- Config sync export (usually committed, uncomment to exclude) ----
# /config/sync/

# ---- Local dev / environment ----
.env
.env.*
!.env.example
*.sqlite
/.ddev/db_snapshots/

# ---- PHP / Composer ----
composer.phar
/vendor/
.phpunit.result.cache

# ---- Node (if a theme uses a build step) ----
node_modules/
npm-debug.log

# ---- Editor / OS cruft ----
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---- Logs ----
*.log
error_log

# ---- Backups / archives some Drupal tooling generates ----
*.sql
*.sql.gz
*.tar.gz